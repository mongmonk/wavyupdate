# Database Configuration
DB_HOST=localhost                    # Database host address
DB_PORT=3306                         # MySQL port (default: 3306)
DB_USER=root                         # Database username
DB_PASSWORD=your_password_here       # Database password
DB_NAME=wavvy                        # Database name
DB_POOL_SIZE=10                      # Maximum connections in pool
DB_POOL_MAX_IDLE=10                  # Maximum idle connections
DB_POOL_IDLE_TIMEOUT=60000           # Idle timeout in milliseconds (60 seconds)
DB_POOL_QUEUE_LIMIT=0                # Queue limit (0 = unlimited)

# Application Configuration
APP_URL=http://localhost:3000        # Application URL
PORT=3000                            # Server port
NODE_ENV=development                 # Environment (development/production)

# Session Configuration
# IMPORTANT: Generate a strong random secret for production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-secret-key  # Secret for session encryption

# Encryption Configuration (REQUIRED for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=                      # 64-character hex string for AES-256-GCM encryption

# WhatsApp Configuration (all values in milliseconds)
WA_QR_TIMEOUT=20000                  # QR code timeout (20 seconds)
WA_MAX_QR_ATTEMPTS=10                # Maximum QR generation attempts
WA_BROWSER_NAME=Traxify              # Browser name for WhatsApp
WA_BROWSER_VERSION=Chrome            # Browser version
WA_APP_VERSION=1.0.0                 # App version
WA_RECONNECT_DELAY=3000              # Initial reconnect delay (3 seconds)
WA_RECONNECT_MAX_DELAY=60000         # Maximum reconnect delay (60 seconds)

# Message Processing (all values in milliseconds)
MSG_RETENTION_TIME=3600000           # Message retention time (1 hour)
MSG_CLEANUP_INTERVAL=600000          # Cleanup interval (10 minutes)
MSG_MAX_PROCESSED=10000              # Maximum processed messages in cache
MSG_MAX_AGE=120000                   # Maximum message age to process (2 minutes)
MSG_BATCH_SAVE_DELAY=5000            # Delay before batch saving (5 seconds)
MSG_BETWEEN_DELAY=500                # Delay between sending multiple messages (500ms)

# Session Cleanup (all values in milliseconds)
SESSION_CLEANUP_INTERVAL=1800000     # Cleanup interval (30 minutes)
SESSION_INACTIVE_TIMEOUT=86400000    # Inactive session timeout (24 hours)

# File Uploads
UPLOAD_MAX_SIZE=52428800             # Maximum file size in bytes (50MB)
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf,audio/mpeg,audio/wav,audio/ogg

# Security
BCRYPT_ROUNDS=10                     # BCrypt hashing rounds
API_KEY_LENGTH=32                    # API key length in bytes

# AI Conversation Cleanup (in days)
AI_CONVERSATION_CLEANUP_DAYS=30      # Delete conversations older than this (0 = never)

# OpenRouter Configuration (optional - for model caching)
OPENROUTER_API_KEY=                  # Your OpenRouter API key (optional)

# Google OAuth Configuration (optional - for Google login)
GOOGLE_CLIENT_ID=                    # Google OAuth Client ID
GOOGLE_CLIENT_SECRET=                # Google OAuth Client Secret
GOOGLE_AUTH_ENABLED=false            # Enable/disable Google authentication (true/false)
# Note: Callback URL is auto-generated from APP_URL as: {APP_URL}/auth/google/callback

# WhatsApp Business API (WABA) Configuration (optional - for OTP verification)
WABA_OTP_ENABLED=false               # Enable/disable WhatsApp OTP verification (true/false)
WABA_PHONE_NUMBER_ID=                # WhatsApp Business Phone Number ID from Meta Business Manager
WABA_ACCESS_TOKEN=                   # WhatsApp Business API Access Token (System User Token)
WABA_BUSINESS_ACCOUNT_ID=            # WhatsApp Business Account ID (optional)
WABA_API_VERSION=v24.0               # WhatsApp Business API version (v18.0, v19.0, v20.0, v21.0, v22.0, v24.0)
WABA_OTP_TEMPLATE_NAME=otp_verification
WABA_OTP_BUTTON_TYPE=url             # Button type in your OTP template: url, copy_code, or none
WABA_PHONE_COUNTRY=international     # Phone validation: pk/pakistan, in/india, us/usa, uk/gb, or international (default)