    <script src="/js/contacts.js"></script>
    <script>
        // Apply dynamic colors from data attributes
        document.addEventListener('DOMContentLoaded', function() {
            // Apply background colors
            document.querySelectorAll('[data-bg-color]').forEach(function(el) {
                var color = el.getAttribute('data-bg-color');
                if (el.classList.contains('contact-avatar-modern')) {
                    el.style.background = 'linear-gradient(135deg, ' + color + ', ' + color + ')';
                } else {
                    el.style.backgroundColor = color;
                }
            });
            // Apply badge colors
            document.querySelectorAll('[data-badge-color]').forEach(function(el) {
                var color = el.getAttribute('data-badge-color');
                el.style.background = color + '20';
                el.style.color = color;
            });
            
            // Mobile Groups Toggle
            var mobileGroupsToggle = document.getElementById('mobileGroupsToggle');
            var groupsSidebar = document.getElementById('groupsSidebar');
            
            if (mobileGroupsToggle && groupsSidebar) {
                mobileGroupsToggle.addEventListener('click', function() {
                    this.classList.toggle('active');
                    groupsSidebar.classList.toggle('show');
                });
            }
        });
    </script>