<% currentPage = 'api-docs' %>

<div class="api-docs-container">
    <!-- Mobile Navigation Toggle -->
    <button class="api-mobile-nav-toggle" id="apiNavToggle">
        <i class="fas fa-bars"></i>
        <span>Navigation</span>
    </button>

    <!-- Sidebar Navigation -->
    <aside class="api-sidebar" id="apiSidebar">
        <div class="api-sidebar-header">
            <h6><i class="fas fa-book me-2"></i>API Guide</h6>
            <button class="api-sidebar-close" id="apiSidebarClose">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <ul class="api-sidebar-nav">
            <li><a href="#getting-started" class="active"><i class="fas fa-rocket"></i>Getting Started</a></li>
            <li><a href="#authentication"><i class="fas fa-key"></i>Authentication</a></li>
        </ul>
        <div class="api-sidebar-section">Session Management</div>
        <ul class="api-sidebar-nav">
            <li><a href="#get-sessions"><i class="fas fa-list"></i>Get Sessions</a></li>
            <li><a href="#create-session"><i class="fas fa-plus-circle"></i>Create Session</a></li>
            <li><a href="#get-session-status"><i class="fas fa-info-circle"></i>Get Session Status</a></li>
            <li><a href="#get-qr-code"><i class="fas fa-qrcode"></i>Get QR Code</a></li>
            <li><a href="#reconnect-session"><i class="fas fa-sync"></i>Reconnect Session</a></li>
            <li><a href="#delete-session"><i class="fas fa-trash"></i>Delete Session</a></li>
        </ul>
        <div class="api-sidebar-section">Messaging</div>
        <ul class="api-sidebar-nav">
            <li><a href="#send-message"><i class="fas fa-paper-plane"></i>Send Message</a></li>
            <li><a href="#send-media"><i class="fas fa-image"></i>Send Media</a></li>
        </ul>
        <div class="api-sidebar-section">Number Checker</div>
        <ul class="api-sidebar-nav">
            <li><a href="#check-numbers"><i class="fas fa-check-circle"></i>Check Numbers</a></li>
        </ul>
        <div class="api-sidebar-section">Resources</div>
        <ul class="api-sidebar-nav">
            <li><a href="#errors"><i class="fas fa-exclamation-triangle"></i>Error Codes</a></li>
            <li><a href="#examples"><i class="fas fa-code"></i>Code Examples</a></li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="api-content">
        <!-- Page Header -->
        <div class="api-page-header mb-4">
            <div class="api-header-icon">
                <i class="fas fa-code"></i>
            </div>
            <div>
                <h1 class="api-docs-main-heading">API Documentation</h1>
                <p class="api-docs-subtitle">
                    Complete guide to integrate WhatsApp messaging into your applications
                </p>
            </div>
        </div>

        <!-- Getting Started -->
        <section id="getting-started" class="api-section">

            <!-- API Key Section - Clean Redesign -->
            <% if (userApiKey) { %>
            <div class="api-key-section">
                <div class="api-key-header-clean">
                    <div class="api-key-icon-clean">
                        <i class="fas fa-key"></i>
                    </div>
                    <div class="api-key-header-text">
                        <h3>Your API Key</h3>
                        <p>Use this key to authenticate your API requests</p>
                    </div>
                    <span class="api-key-badge-secure">
                        <i class="fas fa-shield-alt"></i> Secure
                    </span>
                </div>
                
                <div class="api-key-body-clean">
                    <div class="api-key-input-container">
                        <code id="apiKeyDisplay" data-key="<%= userApiKey %>">••••••••••••••••••••••••••••••••</code>
                        <div class="api-key-buttons">
                            <button class="api-key-btn api-key-btn-toggle" onclick="toggleApiKeyVisibility()" title="Show/Hide" id="btnToggleKey">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="api-key-btn api-key-btn-copy" onclick="copyApiKey()" title="Copy">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="api-key-footer-clean">
                        <button class="api-key-regenerate-btn" onclick="regenerateApiKey()">
                            <i class="fas fa-sync-alt"></i>
                            <span>Regenerate Key</span>
                        </button>
                        <div class="api-key-warning-clean">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>Never share your API key publicly</span>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

            <h2>Base URL</h2>
            <div class="code-block">
                <div class="code-block-header">
                    <span class="code-block-title">API Base URL</span>
                    <button class="copy-code-btn" onclick="copyCode(this)">
                        <i class="fas fa-copy"></i> Copy
                    </button>
                </div>
                <code id="baseUrl"></code>
            </div>

            <div class="info-box info-box-info">
                <strong><i class="fas fa-info-circle me-2"></i>Quick Start</strong><br>
                All API requests require authentication. Include your API key in the <code>X-API-Key</code> header.
            </div>
        </section>

        <!-- Authentication -->
        <section id="authentication" class="api-section">
            <h2>Authentication</h2>
            <p>All API requests must be authenticated by including your API key in the request header:</p>
            
            <div class="code-block">
                <div class="code-block-header">
                    <span class="code-block-title">Required Header</span>
                </div>
                <code>X-API-Key: YOUR_API_KEY</code>
            </div>

            <div class="info-box info-box-warning">
                <strong><i class="fas fa-exclamation-triangle me-2"></i>Security Requirements</strong><br>
                • All API requests must use HTTPS/SSL encryption<br>
                • Never expose your API key in client-side code or public repositories<br>
                • Store API keys securely in environment variables
            </div>
        </section>

        <!-- Get Sessions -->
        <section id="get-sessions" class="api-section">
            <h2><span class="method-badge-inline method-get">GET</span> Get Sessions</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Get session counts for your account</p>

                <h4>Response</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">200 OK</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": true,
  "counts": {
    "total": 5,
    "connected": 3,
    "connecting": 1,
    "qr": 1,
    "disconnected": 0
  }
}</code>
                </div>
            </div>
        </section>

        <!-- Create Session -->
        <section id="create-session" class="api-section">
            <h2><span class="method-badge-inline method-post">POST</span> Create Session</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Create a new WhatsApp session</p>

                <h4>Parameters</h4>
                <table class="param-table">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Type</th>
                            <th>Required</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">sessionName</span></td>
                            <td data-label="Type">string</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">Name for your session</td>
                        </tr>
                    </tbody>
                </table>

                <h4>Request Body</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">JSON</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "sessionName": "My Business Account"
}</code>
                </div>

                <h4>Response</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">201 Created</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": true,
  "sessionId": "abc-123-def-456",
  "message": "Session created successfully"
}</code>
                </div>
            </div>
        </section>

        <!-- Get Session Status -->
        <section id="get-session-status" class="api-section">
            <h2><span class="method-badge-inline method-get">GET</span> Get Session Status</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions/:sessionId</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Get detailed status of a specific session</p>

                <h4>Response</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">200 OK</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": true,
  "session": {
    "id": "abc-123-def-456",
    "name": "My Business Account",
    "status": "connected",
    "phone_number": "1234567890",
    "created_at": "2024-01-01T00:00:00.000Z",
    "isConnected": true
  }
}</code>
                </div>

                <div class="info-box info-box-info">
                    <strong>Status Values:</strong><br>
                    <code>connecting</code> • <code>qr</code> • <code>connected</code> • <code>disconnected</code>
                </div>
            </div>
        </section>
</code>
   
     <!-- Get QR Code -->
        <section id="get-qr-code" class="api-section">
            <h2><span class="method-badge-inline method-get">GET</span> Get QR Code</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions/:sessionId/qr</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Get QR code for session authentication</p>

                <h4>Response</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">200 OK</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": true,
  "qrCode": "data:image/png;base64,iVBORw0KGgo..."
}</code>
                </div>

                <div class="info-box info-box-success">
                    <i class="fas fa-check-circle me-2"></i>
                    The QR code is returned as a base64-encoded PNG image that can be displayed directly in an <code>&lt;img&gt;</code> tag.
                </div>
            </div>
        </section>

        <!-- Reconnect Session -->
        <section id="reconnect-session" class="api-section">
            <h2><span class="method-badge-inline method-post">POST</span> Reconnect Session</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions/:sessionId/reconnect</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Reconnect a session (generates new QR code)</p>

                <div class="info-box info-box-warning">
                    <i class="fas fa-info-circle me-2"></i>
                    This will clear old credentials and require re-scanning the QR code.
                </div>
            </div>
        </section>

        <!-- Delete Session -->
        <section id="delete-session" class="api-section">
            <h2><span class="method-badge-inline method-delete">DELETE</span> Delete Session</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions/:sessionId</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Permanently delete a session</p>

                <div class="info-box info-box-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Warning:</strong> This action cannot be undone. All auto-replies and AI configurations will be deleted.
                </div>
            </div>
        </section>

        <!-- Send Message -->
        <section id="send-message" class="api-section">
            <h2><span class="method-badge-inline method-post">POST</span> Send Message</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions/:sessionId/send</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Send a text message via WhatsApp</p>

                <h4>Parameters</h4>
                <table class="param-table">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Type</th>
                            <th>Required</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">to</span></td>
                            <td data-label="Type">string</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">Phone number with country code (without +)</td>
                        </tr>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">message</span></td>
                            <td data-label="Type">string</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">Message text (max 4096 characters)</td>
                        </tr>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">skipValidation</span></td>
                            <td data-label="Type">boolean</td>
                            <td data-label="Required"><span class="param-optional">Optional</span></td>
                            <td data-label="Description">Skip WhatsApp number validation (default: false)</td>
                        </tr>
                    </tbody>
                </table>

                <div class="info-box info-box-success">
                    <i class="fas fa-shield-alt me-2"></i>
                    <strong>Smart Validation:</strong> By default, the API validates that the phone number is registered on WhatsApp before sending. This prevents wasted attempts and reduces spam risk. Set <code>skipValidation: true</code> to bypass this check.
                </div>

                <h4>Request Body</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">JSON (Basic)</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "to": "1234567890",
  "message": "Hello from WhatsApp API!"
}</code>
                </div>

                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">JSON (Skip Validation)</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "to": "1234567890",
  "message": "Hello from WhatsApp API!",
  "skipValidation": true
}</code>
                </div>

                <h4>Response</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">200 OK - Success</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": true,
  "messageId": "3EB0C767D71D8D6E2CD5",
  "message": "Message sent successfully"
}</code>
                </div>

                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">400 Bad Request - Invalid Number</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": false,
  "error": "Invalid WhatsApp Number",
  "message": "The phone number is not registered on WhatsApp. Please verify the number or use skipValidation: true to bypass this check.",
  "phoneNumber": "1234567890"
}</code>
                </div>
            </div>
        </section>

        <!-- Send Media -->
        <section id="send-media" class="api-section">
            <h2><span class="method-badge-inline method-post">POST</span> Send Media</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/sessions/:sessionId/send-media</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Send media files (images, videos, audio, documents)</p>

                <h4>Parameters (multipart/form-data)</h4>
                <table class="param-table">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Type</th>
                            <th>Required</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">to</span></td>
                            <td data-label="Type">string</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">Phone number with country code</td>
                        </tr>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">media</span></td>
                            <td data-label="Type">file</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">File to send (max 50MB)</td>
                        </tr>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">message</span></td>
                            <td data-label="Type">string</td>
                            <td data-label="Required"><span class="param-optional">Optional</span></td>
                            <td data-label="Description">Caption for the media</td>
                        </tr>
                    </tbody>
                </table>

                <h4>Supported Media Types</h4>
                <div class="media-types-grid">
                    <div class="info-box info-box-info">
                        <strong>Images</strong><br>
                        .jpg, .jpeg, .png, .gif, .webp
                    </div>
                    <div class="info-box info-box-info">
                        <strong>Videos</strong><br>
                        .mp4, .avi, .mov, .mkv, .webm
                    </div>
                    <div class="info-box info-box-info">
                        <strong>Audio</strong><br>
                        .mp3, .wav, .ogg, .m4a, .aac
                    </div>
                    <div class="info-box info-box-info">
                        <strong>Documents</strong><br>
                        .pdf, .doc, .docx, .xls, .xlsx
                    </div>
                </div>

                <h4>Example Request</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">cURL</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>curl -X POST <span class="api-base"></span>/api/sessions/abc-123/send-media \
  -H "X-API-Key: YOUR_API_KEY" \
  -F "to=1234567890" \
  -F "message=Check this out!" \
  -F "media=@/path/to/image.jpg"</code>
                </div>
            </div>
        </section>

        <!-- Check Numbers -->
        <section id="check-numbers" class="api-section">
            <h2><span class="method-badge-inline method-post">POST</span> Check WhatsApp Numbers</h2>
            <div class="endpoint-card">
                <div class="endpoint-header">
                    <div class="endpoint-method-wrapper">
                        <span class="endpoint-path"><span class="api-base"></span>/number-checker/check</span>
                    </div>
                    <button class="copy-endpoint-btn" onclick="copyEndpoint(this)">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <p class="endpoint-description">Validate if phone numbers are registered on WhatsApp</p>

                <h4>Parameters</h4>
                <table class="param-table">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Type</th>
                            <th>Required</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">sessionId</span></td>
                            <td data-label="Type">string</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">Session ID to use for checking</td>
                        </tr>
                        <tr>
                            <td data-label="Parameter"><span class="param-name">phoneNumbers</span></td>
                            <td data-label="Type">array</td>
                            <td data-label="Required"><span class="param-required">Required</span></td>
                            <td data-label="Description">Array of phone numbers with country code (max 100)</td>
                        </tr>
                    </tbody>
                </table>

                <div class="info-box info-box-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Batch Processing:</strong> You can check up to 100 phone numbers in a single request. The API will validate each number against WhatsApp's registry and return detailed results.
                </div>

                <h4>Request Body</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">JSON</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "sessionId": "abc-123-def-456",
  "phoneNumbers": [
    "1234567890",
    "9876543210",
    "5551234567"
  ]
}</code>
                </div>

                <h4>Response</h4>
                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">200 OK - Success</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": true,
  "message": "Number check completed",
  "summary": {
    "total": 3,
    "valid": 2,
    "invalid": 1
  },
  "results": [
    {
      "phoneNumber": "1234567890",
      "isValid": true,
      "status": "valid"
    },
    {
      "phoneNumber": "9876543210",
      "isValid": false,
      "status": "invalid"
    },
    {
      "phoneNumber": "5551234567",
      "isValid": true,
      "status": "valid"
    }
  ]
}</code>
                </div>

                <div class="code-block">
                    <div class="code-block-header">
                        <span class="code-block-title">403 Forbidden - Limit Reached</span>
                        <button class="copy-code-btn" onclick="copyCode(this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <code>{
  "success": false,
  "error": "Number check limit reached",
