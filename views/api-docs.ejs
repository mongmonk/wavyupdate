<script>
// Get CSRF token from meta tag
function getCsrfToken() {
    const meta = document.querySelector('meta[name="csrf-token"]');
    return meta ? meta.getAttribute('content') : null;
}

// Helper function to make authenticated requests
async function fetchWithCsrf(url, options = {}) {
    const csrfToken = getCsrfToken();
    const headers = options.headers || {};
    
    if (csrfToken && ['POST', 'PUT', 'DELETE', 'PATCH'].includes(options.method?.toUpperCase())) {
        headers['x-csrf-token'] = csrfToken;
    }
    
    return fetch(url, {
        ...options,
        headers
    });
}

// Set dynamic base URL
document.addEventListener('DOMContentLoaded', function() {
    const baseUrl = window.location.origin + '/api';
    const baseUrlElement = document.getElementById('baseUrl');
    if (baseUrlElement) {
        baseUrlElement.textContent = baseUrl;
    }
    document.querySelectorAll('.api-base').forEach(el => {
        el.textContent = baseUrl;
    });

    // Mobile Navigation
    const apiNavToggle = document.getElementById('apiNavToggle');
    const apiSidebar = document.getElementById('apiSidebar');
    const apiSidebarClose = document.getElementById('apiSidebarClose');
    let sidebarOverlay = document.querySelector('.api-sidebar-overlay');
    
    if (!sidebarOverlay) {
        sidebarOverlay = document.createElement('div');
        sidebarOverlay.className = 'api-sidebar-overlay';
        document.body.appendChild(sidebarOverlay);
    }

    function openSidebar() {
        apiSidebar.classList.add('active');
        sidebarOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        apiSidebar.classList.remove('active');
        sidebarOverlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    if (apiNavToggle) {
        apiNavToggle.addEventListener('click', openSidebar);
    }

    if (apiSidebarClose) {
        apiSidebarClose.addEventListener('click', closeSidebar);
    }

    if (sidebarOverlay) {
        sidebarOverlay.addEventListener('click', closeSidebar);
    }

    // Smooth scroll for sidebar links
    document.querySelectorAll('.api-sidebar-nav a').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            const targetElement = document.querySelector(targetId);
            
            if (targetElement) {
                // Close mobile sidebar
                if (window.innerWidth <= 992) {
                    closeSidebar();
                }
                
                // Smooth scroll
                setTimeout(() => {
                    targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, window.innerWidth <= 992 ? 300 : 0);
                
                // Update active state
                document.querySelectorAll('.api-sidebar-nav a').forEach(l => l.classList.remove('active'));
                this.classList.add('active');
            }
        });
    });

    // Intersection Observer for active section
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.getAttribute('id');
                document.querySelectorAll('.api-sidebar-nav a').forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === `#${id}`) {
                        link.classList.add('active');
                    }
                });
            }
        });
    }, { threshold: 0.5, rootMargin: '-100px 0px -50% 0px' });

    document.querySelectorAll('.api-section').forEach(section => {
        observer.observe(section);
    });

    // Close sidebar on window resize
    window.addEventListener('resize', function() {
        if (window.innerWidth > 992) {
            closeSidebar();
        }
    });
});

function toggleApiKeyVisibility() {
    const keyDisplay = document.getElementById('apiKeyDisplay');
    const toggleBtn = document.getElementById('btnToggleKey');
    if (!keyDisplay || !toggleBtn) return;
    
    const actualKey = keyDisplay.getAttribute('data-key');
    const isHidden = keyDisplay.textContent.includes('••');
    
    if (isHidden) {
        keyDisplay.textContent = actualKey;
        toggleBtn.innerHTML = '<i class="fas fa-eye-slash"></i>';
        toggleBtn.title = 'Hide API Key';
    } else {
        keyDisplay.textContent = '••••••••••••••••••••••••••••••••';
        toggleBtn.innerHTML = '<i class="fas fa-eye"></i>';
        toggleBtn.title = 'Show API Key';
    }
}

function copyApiKey() {
    const keyDisplay = document.getElementById('apiKeyDisplay');
    if (!keyDisplay) return;
    
    const actualKey = keyDisplay.getAttribute('data-key');
    navigator.clipboard.writeText(actualKey).then(() => {
        if (typeof Toast !== 'undefined') {
            Toast.success('API key copied!');
        } else {
            alert('API key copied to clipboard!');
        }
    }).catch(err => {
        console.error('Failed to copy:', err);
        if (typeof Toast !== 'undefined') {
            Toast.error('Failed to copy API key');
        }
    });
}

async function regenerateApiKey() {
    const confirmMessage = 'This will invalidate your current API key. Any applications using the old key will stop working immediately.\n\nAre you sure you want to continue?';
    
    if (typeof ConfirmModal !== 'undefined') {
        ConfirmModal.show({
            title: 'Regenerate API Key?',
            message: 'This will invalidate your current API key. Any applications using the old key will stop working immediately.<br><br><strong>Are you sure you want to continue?</strong>',
            confirmText: 'Regenerate Key',
            cancelText: 'Cancel',
            type: 'warning',
            icon: 'fa-exclamation-triangle',
            confirmIcon: 'fa-sync-alt',
            onConfirm: async () => {
                await performRegenerate();
            }
        });
    } else {
        if (confirm(confirmMessage)) {
            await performRegenerate();
        }
    }
}

async function performRegenerate() {
    try {
        const response = await fetchWithCsrf('/webapi/users/<%= user.id %>/regenerate-api-key', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();

        if (data.success) {
            const apiKeyDisplay = document.getElementById('apiKeyDisplay');
            if (apiKeyDisplay) {
                // Update the data-key attribute with the new key
                apiKeyDisplay.setAttribute('data-key', data.api_key);
                // Show the new key immediately
                apiKeyDisplay.textContent = data.api_key;
                // Update the toggle button to show "hide" icon
                const toggleBtn = document.getElementById('btnToggleKey');
                if (toggleBtn) {
                    toggleBtn.innerHTML = '<i class="fas fa-eye-slash"></i>';
                    toggleBtn.title = 'Hide API Key';
                }
            }
            if (typeof Toast !== 'undefined') {
                Toast.success('API key regenerated successfully!');
            } else {
                alert('API key regenerated successfully!');
            }
        } else {
            if (typeof Toast !== 'undefined') {
                Toast.error(data.message || 'Failed to regenerate API key');
            } else {
                alert(data.message || 'Failed to regenerate API key');
            }
        }
    } catch (error) {
        console.error('Error regenerating API key:', error);
        if (typeof Toast !== 'undefined') {
            Toast.error('Error regenerating API key');
        } else {
            alert('Error regenerating API key. Please try again.');
        }
    }
}

function copyCode(button) {
    const codeBlock = button.closest('.code-block');
    if (!codeBlock) return;
    
    const codeElement = codeBlock.querySelector('code');
    if (!codeElement) return;
    
    const code = codeElement.textContent;
    navigator.clipboard.writeText(code).then(() => {
        const originalText = button.innerHTML;
        button.innerHTML = '<i class="fas fa-check"></i> Copied!';
        button.style.background = 'rgba(16, 185, 129, 0.2)';
        button.style.color = '#10b981';
        setTimeout(() => {
            button.innerHTML = originalText;
            button.style.background = '';
            button.style.color = '';
        }, 2000);
    }).catch(err => {
        console.error('Failed to copy code:', err);
        if (typeof Toast !== 'undefined') {
            Toast.error('Failed to copy code');
        }
    });
}

function switchTab(language) {
    document.querySelectorAll('.language-tab').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
    
    event.target.classList.add('active');
    document.getElementById(language).classList.add('active');
}

function copyEndpoint(button) {
    const endpointPath = button.previousElementSibling;
    if (!endpointPath) return;
    
    const fullEndpoint = endpointPath.textContent.trim();
    navigator.clipboard.writeText(fullEndpoint).then(() => {
        const originalHTML = button.innerHTML;
        button.innerHTML = '<i class="fas fa-check"></i>';
        button.style.background = 'var(--whatsapp-green)';
        button.style.color = 'white';
        button.style.borderColor = 'var(--whatsapp-green)';
        setTimeout(() => {
            button.innerHTML = originalHTML;
            button.style.background = '';
            button.style.color = '';
            button.style.borderColor = '';
        }, 2000);
    }).catch(err => {
        console.error('Failed to copy endpoint:', err);
        if (typeof Toast !== 'undefined') {
            Toast.error('Failed to copy endpoint');
        }
    });
}
</script>
